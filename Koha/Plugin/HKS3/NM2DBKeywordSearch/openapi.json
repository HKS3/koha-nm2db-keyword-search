{
  "/page": {
    "get": {
      "x-mojo-to": "HKS3::NM2DBKeywordSearch::Controller#page",
      "operationId": "nm2dbKeywordSearchPage",
      "tags": [
        "plugin"
      ],
      "produces": [
        "text/html"
      ],
      "parameters": [
        {
          "name": "keyword",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "type",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "facet_name",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "facet_value",
          "in": "query",
          "required": false,
          "type": "string"
        }
      ],
      "responses": {
        "200": {
          "description": "HTML search page",
          "schema": {
            "type": "string"
          }
        }
      }
    }
  },
  "/search": {
    "get": {
      "x-mojo-to": "HKS3::NM2DBKeywordSearch::Controller#search",
      "operationId": "nm2dbKeywordSearchPublicSearch",
      "tags": [
        "plugin"
      ],
      "produces": [
        "application/json"
      ],
      "parameters": [
        {
          "name": "keyword",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "type",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "facet_name",
          "in": "query",
          "required": false,
          "type": "string"
        },
        {
          "name": "facet_value",
          "in": "query",
          "required": false,
          "type": "string"
        }
      ],
      "responses": {
        "200": {
          "description": "Search results",
          "schema": {
            "type": "object",
            "properties": {
              "keyword": {
                "type": "string"
              },
              "count": {
                "type": "integer"
              },
              "facet_name": {
                "type": "string"
              },
              "facet_value": {
                "type": "string"
              },
              "results": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "biblionumber": {
                      "type": "integer",
                      "x-nullable": true
                    },
                    "tag": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    },
                    "xml": {
                      "type": "string"
                    },
                    "rendered_html": {
                      "type": "string"
                    }
                  }
                }
              },
              "facets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "values": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "value": {
                            "type": "string"
                          },
                          "count": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
