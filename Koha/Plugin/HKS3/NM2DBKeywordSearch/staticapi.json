{
  "/ui/search.html": {
    "get": {
      "x-mojo-to": "Static#get",
      "tags": [
        "pluginStatic"
      ],
      "responses": {
        "200": {
          "description": "File found",
          "schema": {
            "type": "file"
          }
        },
        "404": {
          "description": "File not found",
          "schema": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
